                  dataType="System.String"
                  description="Commande SQL à exécuter."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=17.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">SELECT DISTINCT
    CleanSpeculation AS SpeculationName
FROM (
    SELECT LTRIM(RTRIM(CAST([Spéculation] AS NVARCHAR(MAX)))) AS CleanSpeculation
    FROM STAGING.dbo.STG_Kiwa
    UNION
    SELECT LTRIM(RTRIM(CAST([Spéculation] AS NVARCHAR(MAX))))
    FROM STAGING.dbo.STG_CCPB
    UNION
    SELECT LTRIM(RTRIM(CAST([Spéculation] AS NVARCHAR(MAX))))
    FROM STAGING.dbo.STG_Ecocert
) S
WHERE CleanSpeculation IS NOT NULL
  AND CleanSpeculation &lt;&gt; ''
  AND NOT EXISTS (
        SELECT 1
        FROM DWH.dbo.DimSpeculation D
        WHERE D.SpeculationName = S.CleanSpeculation
  );</property>
