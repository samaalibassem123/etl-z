                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=17.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">WITH src AS
(
    SELECT
        'Kiwa' AS SourceFile,
        Organisme,
        Code,
        Projet,
        Gouvernorat,
        [Nom reponsable] AS NomResponsable,
        [Contact mail] AS ContactMail,
        Telephone1,
        Telephone2,
        Fax,
        [Activité] AS Activite,
        CAST([Spéculation] AS NVARCHAR(MAX)) AS Speculation,
        Superficie,
        [Nombre des opérateurs] AS NombreOperateurs,
        Estimation,
        Producteur,
        Ceuilleur AS Ceuilleur,
        Transfo,
        Exporter,
        aquaculteur AS Aquaculteur
    FROM STAGING.dbo.STG_Kiwa

    UNION ALL

    SELECT
        'CCPB' AS SourceFile,
        Organisme,
        Code,
        Projet,
        Gouvernorat,
        [Nom reponsable] AS NomResponsable,
        [Contact mail] AS ContactMail,
        Telephone1,
        Telephone2,
        Fax,
        [Activité] AS Activite,
        CAST([Spéculation] AS NVARCHAR(MAX)) AS Speculation,
        Superficie,
        [Nombre des opérateurs] AS NombreOperateurs,
        Estimation,
        Producteur,
        [Ceuilleir] AS Ceuilleur,
        Transfo,
        Exporter,
        [aquacultuer] AS Aquaculteur
    FROM STAGING.dbo.STG_CCPB

    UNION ALL

    SELECT
        'Ecocert' AS SourceFile,
        Organisme,
        Code,
        Projet,
        Gouvernorat,
        [Nom reponsable] AS NomResponsable,
        [Contact mail] AS ContactMail,
        Telephone1,
        Telephone2,
        Fax,
        [Activité] AS Activite,
        CAST([Spéculation] AS NVARCHAR(MAX)) AS Speculation,
        Superficie,
        [Nombre des opérateurs] AS NombreOperateurs,
        Estimation,
        Producteur,
        [Ceuilleir] AS Ceuilleur,
        Transfo,
        Exporter,
        aquaculteur AS Aquaculteur
    FROM STAGING.dbo.STG_Ecocert
)
SELECT
    src.SourceFile,
    src.Organisme,
    src.Code,
    src.Projet,
    src.Gouvernorat,
    src.Activite,
    src.Speculation,

    o.OrganismeKey,
    p.ProjetKey,
    g.GouvernoratKey,
    a.ActiviteKey,
    s.SpeculationKey,

    TRY_CONVERT(DECIMAL(18,2), NULLIF(LTRIM(RTRIM(src.Superficie)), '')) AS Superficie,
    TRY_CONVERT(INT, NULLIF(LTRIM(RTRIM(src.NombreOperateurs)), ''))     AS NombreOperateurs,
    TRY_CONVERT(DECIMAL(18,2), NULLIF(LTRIM(RTRIM(src.Estimation)), '')) AS Estimation,
    TRY_CONVERT(INT, NULLIF(LTRIM(RTRIM(src.Producteur)), ''))           AS Producteur,
    TRY_CONVERT(INT, NULLIF(LTRIM(RTRIM(src.Ceuilleur)), ''))            AS Ceuilleur,
    TRY_CONVERT(INT, NULLIF(LTRIM(RTRIM(src.Transfo)), ''))              AS Transfo,
    TRY_CONVERT(INT, NULLIF(LTRIM(RTRIM(src.Exporter)), ''))             AS Exporter,
    TRY_CONVERT(INT, NULLIF(LTRIM(RTRIM(src.Aquaculteur)), ''))          AS Aquaculteur
FROM src
LEFT JOIN DWH.dbo.DimOrganisme o
    ON o.OrganismeName = LTRIM(RTRIM(src.Organisme))
LEFT JOIN DWH.dbo.DimProjet p
    ON p.OrganismeKey = o.OrganismeKey
   AND p.Code = LTRIM(RTRIM(src.Code))
LEFT JOIN DWH.dbo.DimGouvernorat g
    ON g.GouvernoratName = LTRIM(RTRIM(src.Gouvernorat))
LEFT JOIN DWH.dbo.DimActivite a
    ON a.ActiviteName = LTRIM(RTRIM(src.Activite))
LEFT JOIN DWH.dbo.DimSpeculation s
    ON s.SpeculationName = LTRIM(RTRIM(src.Speculation));</property>
